import pandas as pd

# 🔹 Step 1: Import dataset (CSV file)
# Replace 'data.csv' with your file path
df = pd.read_csv('data.csv')

# 🔹 Step 2: Show basic details
print("🔸 First 5 Rows:")
print(df.head())

print("\n🔸 Number of Rows and Columns:")
print("Rows:", df.shape[0])
print("Columns:", df.shape[1])

print("\n🔸 Dataset Size (Total elements):")
print(df.size)

# 🔹 Step 3: Missing values
print("\n🔸 Missing Values in Each Column:")
print(df.isnull().sum())

# 🔹 Step 4: Numerical analysis
numeric_df = df.select_dtypes(include=['number'])

print("\n🔸 Sum of Numerical Columns:")
print(numeric_df.sum())

print("\n🔸 Average (Mean) of Numerical Columns:")
print(numeric_df.mean())

print("\n🔸 Minimum Values:")
print(numeric_df.min())

print("\n🔸 Maximum Values:")
print(numeric_df.max())

# 🔹 Step 5: Export dataset (optional)
df.to_csv('output.csv', index=False)
print("\n✅ Dataset exported as 'output.csv'")
